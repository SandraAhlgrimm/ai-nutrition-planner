{
  "uid": "nutrition-planner-agent",
  "title": "AI Nutrition Planner — Agent Observability",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    { "type": "row", "id": 1, "title": "Agent Overview", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 } },

    {
      "type": "stat", "id": 2, "title": "Active Agents",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] } } },
      "targets": [{ "expr": "agent_active", "legendFormat": "Active" }]
    },

    {
      "type": "stat", "id": 3, "title": "Plans Generated",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "targets": [{ "expr": "agent_invocations_total{agent=\"createNutritionPlan\"}", "legendFormat": "Total" }]
    },

    {
      "type": "stat", "id": 4, "title": "p95 Plan Duration",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 90 }] } } },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(agent_duration_milliseconds_bucket{agent=\"createNutritionPlan\"}[5m])) / 1000", "legendFormat": "p95" }]
    },

    {
      "type": "stat", "id": 5, "title": "Total Agent Invocations",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } },
      "targets": [{ "expr": "sum(agent_invocations_total)", "legendFormat": "Total" }]
    },

    {
      "type": "stat", "id": 6, "title": "HTTP Request Rate",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "purple", "mode": "fixed" } } },
      "targets": [{ "expr": "sum(rate(http_server_requests_milliseconds_count[5m]))", "legendFormat": "req/s" }]
    },

    {
      "type": "stat", "id": 7, "title": "Validation Loops",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 1 }] } } },
      "targets": [{ "expr": "agent_invocations_total{agent=\"reviseMealPlan\"}", "legendFormat": "Revisions" }]
    },

    { "type": "row", "id": 10, "title": "Agent Execution", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 } },

    {
      "type": "timeseries", "id": 11, "title": "Agent Duration — p95",
      "gridPos": { "x": 0, "y": 6, "w": 16, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(agent_duration_milliseconds_bucket{agent=\"fetchSeasonalIngredients\"}[5m])) / 1000", "legendFormat": "Seasonal Ingredients" },
        { "expr": "histogram_quantile(0.95, rate(agent_duration_milliseconds_bucket{agent=\"createMealPlan\"}[5m])) / 1000", "legendFormat": "Create Meal Plan" },
        { "expr": "histogram_quantile(0.95, rate(agent_duration_milliseconds_bucket{agent=\"validate\"}[5m])) / 1000", "legendFormat": "Validate" },
        { "expr": "histogram_quantile(0.95, rate(agent_duration_milliseconds_bucket{agent=\"reviseMealPlan\"}[5m])) / 1000", "legendFormat": "Revise Meal Plan" }
      ]
    },

    {
      "type": "timeseries", "id": 12, "title": "Active Agents & HTTP Requests",
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "agent_active", "legendFormat": "Active Agents" },
        { "expr": "sum(http_server_requests_active_milliseconds_count)", "legendFormat": "Active HTTP" }
      ]
    },

    { "type": "row", "id": 20, "title": "Agent Invocations", "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 } },

    {
      "type": "timeseries", "id": 21, "title": "Agent Invocation Rate",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        { "expr": "rate(agent_invocations_total{agent=\"fetchSeasonalIngredients\"}[5m])", "legendFormat": "Seasonal Ingredients" },
        { "expr": "rate(agent_invocations_total{agent=\"createMealPlan\"}[5m])", "legendFormat": "Create Meal Plan" },
        { "expr": "rate(agent_invocations_total{agent=\"validate\"}[5m])", "legendFormat": "Validate" },
        { "expr": "rate(agent_invocations_total{agent=\"reviseMealPlan\"}[5m])", "legendFormat": "Revise Meal Plan" }
      ]
    },

    {
      "type": "timeseries", "id": 22, "title": "HTTP Endpoint Latency — p95",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(http_server_requests_milliseconds_bucket{uri=\"/plan\"}[5m])) / 1000", "legendFormat": "POST /plan" },
        { "expr": "histogram_quantile(0.95, rate(http_server_requests_milliseconds_bucket{uri=\"/plan/stream\"}[5m])) / 1000", "legendFormat": "GET /plan/stream (SSE)" },
        { "expr": "histogram_quantile(0.95, rate(http_server_requests_milliseconds_bucket{uri=\"/plan/result\"}[5m])) / 1000", "legendFormat": "GET /plan/result" }
      ]
    },

    { "type": "row", "id": 30, "title": "JVM & System", "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 } },

    {
      "type": "timeseries", "id": 31, "title": "JVM Memory",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "Heap Used" },
        { "expr": "sum(jvm_memory_committed_bytes{area=\"heap\"})", "legendFormat": "Heap Committed" },
        { "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})", "legendFormat": "Heap Max" }
      ]
    },

    {
      "type": "timeseries", "id": 32, "title": "JVM Threads & GC",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "jvm_threads_live", "legendFormat": "Live Threads" },
        { "expr": "jvm_threads_daemon", "legendFormat": "Daemon Threads" },
        { "expr": "rate(jvm_gc_pause_milliseconds_count[5m])", "legendFormat": "GC Pauses/s" }
      ]
    },

    { "type": "row", "id": 50, "title": "Traces", "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 } },

    {
      "type": "traces", "id": 51, "title": "Plan Generation Traces",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 15 },
      "datasource": { "uid": "tempo" },
      "options": {},
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name=\"langchain4j-nutrition-planner\" && name=~\"http post.*plan\"}",
          "limit": 20
        }
      ]
    }
  ]
}
